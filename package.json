{
  "name": "spring-forge",
  "displayName": "Spring Forge",
  "description": "Visual Spring project generator powered by official start.spring.io API",
  "version": "1.0.2",
  "publisher": "chimaek",
  "license": "MIT",
  "icon": "resources/image.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/chimaek/spring-forge"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "galleryBanner": {
    "color": "#6DB33F",
    "theme": "dark"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "spring",
    "spring boot",
    "initializr",
    "java",
    "kotlin",
    "project generator",
    "gradle",
    "maven"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "spring-forge.open",
        "title": "Spring: New Project (Initializr UI)",
        "icon": "$(add)"
      }
    ],
    "keybindings": [
      {
        "command": "spring-forge.open",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "spring-forge",
          "title": "Spring Initializr",
          "icon": "resources/icon-sprout-stamp.svg"
        }
      ]
    },
    "views": {
      "spring-forge": [
        {
          "id": "spring-forge.welcome",
          "name": "Spring Initializr"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "spring-forge.welcome",
        "contents": "Spring Boot 프로젝트를 생성합니다.\n[New Spring Project](command:spring-forge.open)\nCtrl+Alt+S (Mac: Cmd+Option+S)로도 열 수 있습니다."
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "spring-forge.open",
          "when": "view == spring-forge.welcome",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Spring Forge",
      "properties": {
        "springForge.initializrUrl": {
          "type": "string",
          "default": "https://start.spring.io",
          "description": "Base URL of the Spring Initializr server (e.g., https://start.spring.io or a custom enterprise server).",
          "pattern": "^https://.+",
          "patternErrorMessage": "Must be a valid HTTPS URL"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit",
    "compile": "npm run check-types && node esbuild.js",
    "vscode:prepublish": "npm run package",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "package": "npm run clean && npm run check-types && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "pretest": "npm run compile-tests",
    "test": "node ./out/test/runTest.js",
    "test:unit": "mocha --require ts-node/register src/test/suite/**/*.test.ts",
    "lint": "eslint src --ext ts",
    "vsix": "node -e \"require('fs').readdirSync('.').filter(f=>f.endsWith('.vsix')).forEach(f=>require('fs').unlinkSync(f))\" && npx @vscode/vsce package --no-dependencies"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3",
    "mocha": {
      "minimatch": ">=5.1.8"
    }
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/unzipper": "^0.10.9",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.25.0",
    "eslint": "^8.56.0",
    "jsdom": "^28.1.0",
    "mocha": "^10.2.0",
    "nock": "^13.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "unzipper": "^0.12.0"
  }
}
